{
  "workspace": ["./projects/cli", "./projects/backend", "./projects/ui"],
  "tasks": {
    "mac": "deno run --allow-run --allow-env --allow-read --allow-write --allow-net projects/cli/src/bootstrap.ts",
    "install": "deno install --global -A -f -n arachne --config projects/cli/deno.json projects/cli/src/bootstrap.ts",
    "backend": "deno run -A projects/backend/main.ts",
    "backend:dev": "deno run -A --watch projects/backend/main.ts"
  }
}
