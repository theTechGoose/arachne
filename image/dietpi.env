# DietPi automation overrides
# Applied on top of the default dietpi.txt that ships with the image.
# Format: KEY=VALUE (one per line, # comments allowed)

# Fully automated first boot — no manual interaction
AUTO_SETUP_AUTOMATED=1
AUTO_SETUP_HEADLESS=1

# Boot to console (no desktop)
AUTO_SETUP_AUTOSTART_TARGET_INDEX=0

# Hostname
AUTO_SETUP_NET_HOSTNAME=arachne

# Default global password (change after first boot)
AUTO_SETUP_GLOBAL_PASSWORD=dietpi

# SSH server: OpenSSH
AUTO_SETUP_SSH_SERVER_INDEX=-1

# Allow SSH password login (needed for initial ssh-copy-id)
SOFTWARE_DISABLE_SSH_PASSWORD_LOGINS=0

# Run custom first-boot script
AUTO_SETUP_CUSTOM_SCRIPT_EXEC=/boot/first-boot.sh
